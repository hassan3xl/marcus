# Example env for local development when running Postgres via docker-compose
# Start the DB: `docker compose up -d db`

SECRET_KEY=fallback-secret-key
# Postgres connection (container maps 5432 -> 5433 on host as per docker-compose.yml)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=mstore_db
DB_USER=devuser
DB_PASSWORD=dev_password

# Django dev flags
DEBUG=True
